{
  "name": "mensch-aergere-dich-nicht",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c red,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --config client/vite.config.ts --host 127.0.0.1 --port 5173",
    "dev:server": "tsx watch server/src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "vite build --config client/vite.config.ts && tsc -p server/tsconfig.json",
    "start": "tsx server/src/index.ts"
  },
  "dependencies": {
    "@colyseus/core": "^0.17.41",
    "@colyseus/schema": "^4.0.19",
    "@colyseus/sdk": "^0.17.39",
    "@colyseus/ws-transport": "^0.17.13",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
